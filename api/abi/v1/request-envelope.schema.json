{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yourikka/minicloud/api/abi/v1/request-envelope.schema.json",
  "title": "MiniCloud wasi-command-v1 RequestEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "invocation_id",
    "method",
    "path",
    "query",
    "headers",
    "body_base64",
    "deadline_unix_ms",
    "trigger"
  ],
  "properties": {
    "spec_version": {"const": "1.0"},
    "invocation_id": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{1,128}$"},
    "method": {"type": "string", "minLength": 1, "maxLength": 16, "pattern": "^[!#$%&'*+.^_`|~0-9A-Z-]+$"},
    "path": {"type": "string", "minLength": 1, "maxLength": 4096, "pattern": "^/"},
    "query": {
      "type": "object",
      "maxProperties": 128,
      "additionalProperties": {"type": "array", "items": {"type": "string"}}
    },
    "headers": {"$ref": "#/$defs/headers"},
    "body_base64": {"type": "string", "contentEncoding": "base64"},
    "deadline_unix_ms": {"type": "integer", "minimum": 1},
    "trigger": {"$ref": "#/$defs/trigger"}
  },
  "$defs": {
    "headers": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": {"pattern": "^[!#$%&'*+.^_`|~0-9a-z-]+$"},
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string", "maxLength": 8192}
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {"enum": ["http", "cron", "event"]},
        "id": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{1,128}$"},
        "resource_revision": {"type": "integer", "minimum": 1},
        "fire_id": {"type": "string"},
        "scheduled_time_utc": {"type": "string", "format": "date-time"},
        "receipt_id": {"type": "string"},
        "event_id": {"type": "string"},
        "source_id": {"type": "string"},
        "event_type": {"type": "string"},
        "occurred_at": {"type": "string", "format": "date-time"},
        "content_type": {"type": "string"}
      }
    }
  }
}
